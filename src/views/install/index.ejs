<h1>First-Run Installer</h1><% if(installed){ %><div class="card"><p>Installation is already completed.</p><a href="/auth/login">Login</a></div><% } else { %><form class="form" method="post" action="/install"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Business Name<input name="businessName" required></label><label>Owner Name<input name="ownerName" required></label><label>Email<input type="email" name="email" required></label><label>Password<input type="password" name="password" required minlength="10"></label><button>Install</button></form><% } %>