<h1>Reviews</h1>
<form class="form" method="post" action="/admin/reviews">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>Customer
    <select name="customerId">
      <% customers.forEach(c => { %><option value="<%= c.id %>"><%= c.firstName %> <%= c.lastName %></option><% }) %>
    </select>
  </label>
  <label>Rating <input name="rating" type="number" min="1" max="5" required></label>
  <label>Source <input name="source" value="Google"></label>
  <label>Comments <input name="comments"></label>
  <label>Received At <input name="receivedAt" type="datetime-local"></label>
  <button>Add Review</button>
</form>

<table>
<tr><th>Customer</th><th>Rating</th><th>Source</th><th>Comments</th></tr>
<% reviews.forEach(r => { const c = customers.find(x => x.id === r.customerId) || {}; %>
<tr><td><%= c.firstName || r.customerId %> <%= c.lastName || '' %></td><td><%= r.rating %></td><td><%= r.source %></td><td><%= r.comments %></td></tr>
<% }) %>
</table>
