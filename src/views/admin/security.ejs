<h1>Security Status</h1><div class="kpis"><div><strong><%= summary.passed %></strong><span>Passed</span></div><div><strong><%= summary.failed %></strong><span>Failed</span></div></div><table><tr><th>Check</th><th>Status</th><th>Detail</th></tr><% summary.rows.forEach(r=>{ %><tr><td><%= r.name %></td><td><%= r.ok ? 'PASS' : 'FAIL' %></td><td><%= r.detail %></td></tr><% }) %></table>