<h1>Referral Sources</h1>
<form class="form" method="post" action="/admin/referrals">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>Name <input name="name" required></label>
  <label>Category <input name="category" value="Advertising"></label>
  <button>Add Source</button>
</form>

<table>
<tr><th>Name</th><th>Category</th><th>Customer Count</th></tr>
<% rows.forEach(row => { %>
<tr><td><%= row.source.name %></td><td><%= row.source.category %></td><td><%= row.count %></td></tr>
<% }) %>
</table>
