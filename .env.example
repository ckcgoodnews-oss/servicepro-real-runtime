NODE_ENV=development
PORT=3000
DEFAULT_TENANT_ID=tenant_demo
DATA_STORE=json
DATA_FILE=./data/servicepro-runtime.json
DATABASE_URL=postgresql://servicepro:servicepro@localhost:5432/servicepro
DATABASE_SSL=false

JWT_SECRET=replace-this-with-a-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=3600
PORTAL_TOKEN_SECRET=replace-this-with-a-long-random-portal-secret
PORTAL_TOKEN_TTL_SECONDS=3600

APP_NAME=ServicePro
APP_VERSION=0.69.0
LOG_LEVEL=info

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_JSON_BODY_BYTES=1048576
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_MAX_REQUESTS=12
