NODE_ENV=production
PORT=3000
APP_NAME=ServicePro
APP_VERSION=0.71.0
DEFAULT_TENANT_ID=tenant_demo

DATA_STORE=postgres
DATABASE_URL=postgresql://servicepro:CHANGE_ME@db-host:5432/servicepro
DATABASE_SSL=true

JWT_SECRET=CHANGE_ME_USE_64_PLUS_RANDOM_CHARS
ACCESS_TOKEN_TTL_SECONDS=3600
PORTAL_TOKEN_SECRET=CHANGE_ME_USE_64_PLUS_RANDOM_CHARS
PORTAL_TOKEN_TTL_SECONDS=3600

LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://portal.yourdomain.com
MAX_JSON_BODY_BYTES=1048576
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_MAX_REQUESTS=12
