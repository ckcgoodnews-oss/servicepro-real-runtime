<%- include('../partials/nav') %><main class="container"><section class="hero" style="border-top:6px solid <%= settings.primary_color %>"><h1><%= settings.business_name %></h1><p><%= settings.website_headline %></p><p><strong>Call:</strong> <%= settings.phone || 'Configure phone number' %></p></section><% if (ok) { %><p class="success">Your request was submitted.</p><% } %><h2>Services</h2><div class="grid"><% services.forEach(s=>{ %><div class="card"><h3><%= s.name %></h3><p><%= s.description %></p><strong>$<%= Number(s.base_price||0).toFixed(2) %> starting</strong></div><% }) %></div><h2>Pricing</h2><div class="card"><table><tr><th>Service</th><th>Item</th><th>Amount</th></tr><% pricing.forEach(p=>{ %><tr><td><%= p.service_name || '' %></td><td><%= p.name %></td><td>$<%= Number(p.amount).toFixed(2) %></td></tr><% }) %></table></div><h2>Request Service</h2><form method="post" action="/t/<%= tenant.slug %>/request-service" class="card form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>First Name<input name="first_name" required></label><label>Last Name<input name="last_name" required></label><label>Phone<input name="phone"></label><label>Email<input name="email" type="email"></label><label>Address<input name="address"></label><label>City<input name="city"></label><label>State<input name="state"></label><label>ZIP<input name="zip"></label><label>Service<select name="service_id"><option value="">Select</option><% services.forEach(s=>{ %><option value="<%= s.id %>"><%= s.name %></option><% }) %></select></label><label>Priority<select name="priority"><option>normal</option><option>urgent</option><option>emergency</option></select></label><label class="full">Problem Description<textarea name="description"></textarea></label><button>Submit Request</button></form></main>
