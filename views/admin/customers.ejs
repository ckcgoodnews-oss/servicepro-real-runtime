<%- include('../partials/nav') %><main class="container"><h1>Customers</h1><form method="post" class="card form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>First<input name="first_name" required></label><label>Last<input name="last_name" required></label><label>Phone<input name="phone"></label><label>Email<input name="email" type="email"></label><label>Address<input name="address"></label><label>City<input name="city"></label><label>State<input name="state"></label><label>ZIP<input name="zip"></label><label class="full">Notes<textarea name="notes"></textarea></label><button>Add Customer</button></form><div class="card"><table><tr><th>Name</th><th>Phone</th><th>Email</th><th>City</th><th></th></tr><% rows.forEach(r=>{ %><tr><td><%= r.first_name %> <%= r.last_name %></td><td><%= r.phone || '' %></td><td><%= r.email || '' %></td><td><%= r.city || '' %></td><td><a href="/admin/customers/<%= r.id %>">View</a></td></tr><% }) %></table></div></main>
