<h1>Jobs</h1>
<section class="card">
  <h2>Create Job</h2>
  <form method="post" action="/admin/jobs" class="grid-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Title<input name="title" required></label>
    <label>Customer<select name="customer_id"><option value="">None</option><% customers.forEach(c=>{ %><option value="<%= c.id %>"><%= c.first_name %> <%= c.last_name %></option><% }) %></select></label>
    <label>Service<select name="service_id"><option value="">None</option><% services.forEach(s=>{ %><option value="<%= s.id %>"><%= s.name %></option><% }) %></select></label>
    <label>Technician<select name="assigned_user_id"><option value="">Unassigned</option><% techs.forEach(t=>{ %><option value="<%= t.id %>"><%= t.name %></option><% }) %></select></label>
    <label>Status<select name="status"><% statuses.forEach(s=>{ %><option value="<%= s %>"><%= s %></option><% }) %></select></label>
    <label>Priority<select name="priority"><option>normal</option><option>urgent</option><option>emergency</option></select></label>
    <label>Scheduled<input name="scheduled_at" type="datetime-local"></label>
    <label>Estimate<input name="estimated_price" type="number" step="0.01" min="0"></label>
    <label class="span-2">Description<textarea name="description"></textarea></label>
    <button>Create Job</button>
  </form>
</section>
<section class="card">
  <h2>Job List</h2>
  <table><thead><tr><th>Title</th><th>Customer</th><th>Service</th><th>Technician</th><th>Status</th><th>Scheduled</th><th></th></tr></thead><tbody>
  <% jobs.forEach(j=>{ %>
    <tr><td><a href="/admin/jobs/<%= j.id %>"><%= j.title %></a></td><td><%= j.first_name || '' %> <%= j.last_name || '' %></td><td><%= j.service_name %></td><td><%= j.assigned_name || 'Unassigned' %></td><td><%= j.status %></td><td><%= j.scheduled_at || '' %></td><td><a href="/admin/jobs/<%= j.id %>/edit">Edit</a></td></tr>
  <% }) %>
  </tbody></table>
</section>
