<%- include('../partials/nav') %><main class="container"><h1>Services</h1><form method="post" class="card form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Name<input name="name" required></label><label>Base Price<input name="base_price" type="number" step="0.01"></label><label class="full">Description<textarea name="description"></textarea></label><button>Add Service</button></form><div class="card"><table><tr><th>Name</th><th>Description</th><th>Base</th></tr><% rows.forEach(r=>{ %><tr><td><%= r.name %></td><td><%= r.description || '' %></td><td>$<%= Number(r.base_price||0).toFixed(2) %></td></tr><% }) %></table></div></main>
