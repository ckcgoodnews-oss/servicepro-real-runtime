<h1>Estimates</h1>
<section class="card">
  <h2>Create Estimate</h2>
  <form method="post" action="/admin/estimates" class="grid-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Title<input name="title" required></label>
    <label>Customer<select name="customer_id"><option value="">None</option><% customers.forEach(c=>{ %><option value="<%= c.id %>"><%= c.first_name %> <%= c.last_name %></option><% }) %></select></label>
    <label>Service<select name="service_id"><option value="">None</option><% services.forEach(s=>{ %><option value="<%= s.id %>"><%= s.name %></option><% }) %></select></label>
    <label>Amount<input name="amount" type="number" step="0.01" min="0" required></label>
    <label class="span-2">Description<textarea name="description"></textarea></label>
    <label class="span-2">Line Description<input name="line_description"></label>
    <button>Create Estimate</button>
  </form>
</section>
<section class="card">
  <h2>Estimate List</h2>
  <table><thead><tr><th>Title</th><th>Customer</th><th>Service</th><th>Status</th><th>Total</th><th></th></tr></thead><tbody>
  <% estimates.forEach(e=>{ %><tr><td><a href="/admin/estimates/<%= e.id %>"><%= e.title %></a></td><td><%= e.customer_name %></td><td><%= e.service_name %></td><td><%= e.status %></td><td>$<%= Number(e.total||0).toFixed(2) %></td><td><a href="/admin/estimates/<%= e.id %>">Open</a></td></tr><% }) %>
  </tbody></table>
</section>
