<h1>Dispatch Calendar</h1>
<section class="card">
  <h2>Scheduled / Open Jobs</h2>
  <table>
    <thead><tr><th>Job</th><th>Customer</th><th>Service</th><th>Technician</th><th>Status</th><th>Scheduled</th><th>Dispatch</th></tr></thead>
    <tbody>
      <% jobs.forEach(j=>{ %>
        <tr>
          <td><a href="/admin/jobs/<%= j.id %>"><%= j.title %></a></td>
          <td><%= j.customer_name %></td>
          <td><%= j.service_name %></td>
          <td><%= j.tech_name %></td>
          <td><%= j.status %></td>
          <td><%= j.scheduled_at || '' %></td>
          <td>
            <form method="post" action="/admin/dispatch/<%= j.id %>/assign" class="inline stack-mini">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <select name="assigned_user_id"><option value="">Unassigned</option><% techs.forEach(t=>{ %><option value="<%= t.id %>" <%= j.assigned_user_id===t.id?'selected':'' %>><%= t.name %></option><% }) %></select>
              <input type="datetime-local" name="scheduled_at" value="<%= j.scheduled_at || '' %>">
              <select name="status"><% statuses.forEach(s=>{ %><option value="<%= s %>" <%= j.status===s?'selected':'' %>><%= s %></option><% }) %></select>
              <button>Save</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
