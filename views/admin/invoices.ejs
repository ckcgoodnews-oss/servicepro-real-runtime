<h1>Invoices</h1>
<section class="card">
  <h2>Create Invoice</h2>
  <form method="post" action="/admin/invoices" class="grid-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Title<input name="title" required></label>
    <label>Customer<select name="customer_id"><option value="">None</option><% customers.forEach(c=>{ %><option value="<%= c.id %>"><%= c.first_name %> <%= c.last_name %></option><% }) %></select></label>
    <label>Job<select name="job_id"><option value="">None</option><% jobs.forEach(j=>{ %><option value="<%= j.id %>"><%= j.title %></option><% }) %></select></label>
    <label>Amount<input name="amount" type="number" step="0.01" min="0" required></label>
    <label>Due Date<input name="due_date" type="date"></label>
    <label class="span-2">Line Description<input name="line_description"></label>
    <button>Create Invoice</button>
  </form>
</section>
<section class="card">
  <h2>Invoice List</h2>
  <table><thead><tr><th>Number</th><th>Title</th><th>Customer</th><th>Status</th><th>Total</th><th>Paid</th></tr></thead><tbody>
  <% invoices.forEach(i=>{ %><tr><td><a href="/admin/invoices/<%= i.id %>"><%= i.invoice_number %></a></td><td><%= i.title %></td><td><%= i.customer_name %></td><td><%= i.status %></td><td>$<%= Number(i.total||0).toFixed(2) %></td><td>$<%= Number(i.amount_paid||0).toFixed(2) %></td></tr><% }) %>
  </tbody></table>
</section>
