<%- include('../partials/nav') %><main class="container"><h1><%= tenant ? tenant.name : 'Dashboard' %></h1><div class="grid"><div class="stat">Customers<strong><%= stats.customers %></strong></div><div class="stat">Jobs<strong><%= stats.jobs %></strong></div><div class="stat">Open Jobs<strong><%= stats.openJobs %></strong></div><div class="stat">Services<strong><%= stats.services %></strong></div></div><h2>Recent Jobs</h2><div class="card"><table><tr><th>Title</th><th>Customer</th><th>Status</th><th>Scheduled</th></tr><% jobs.forEach(j=>{ %><tr><td><%= j.title %></td><td><%= [j.first_name,j.last_name].filter(Boolean).join(' ') %></td><td><%= j.status %></td><td><%= j.scheduled_at || '' %></td></tr><% }) %></table></div></main>
