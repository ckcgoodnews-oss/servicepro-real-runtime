<%- include('../partials/nav') %><main class="container"><h1>Pricing</h1><form method="post" class="card form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Name<input name="name" required></label><label>Service<select name="service_id"><option value="">None</option><% services.forEach(s=>{ %><option value="<%= s.id %>"><%= s.name %></option><% }) %></select></label><label>Amount<input name="amount" type="number" step="0.01" required></label><label class="full">Notes<textarea name="notes"></textarea></label><button>Add Price</button></form><div class="card"><table><tr><th>Service</th><th>Name</th><th>Amount</th><th>Notes</th></tr><% rows.forEach(r=>{ %><tr><td><%= r.service_name || '' %></td><td><%= r.name %></td><td>$<%= Number(r.amount||0).toFixed(2) %></td><td><%= r.notes || '' %></td></tr><% }) %></table></div></main>
