<%- include('../partials/nav') %><main class="container narrow"><h1>Business Settings</h1><form method="post" class="card"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Business Name<input name="business_name" value="<%= settings.business_name %>" required></label><label>Phone<input name="phone" value="<%= settings.phone || '' %>"></label><label>Email<input name="email" type="email" value="<%= settings.email || '' %>"></label><label>Address<input name="address" value="<%= settings.address || '' %>"></label><label>City<input name="city" value="<%= settings.city || '' %>"></label><label>State<input name="state" value="<%= settings.state || '' %>"></label><label>ZIP<input name="zip" value="<%= settings.zip || '' %>"></label><label>Headline<input name="website_headline" value="<%= settings.website_headline || '' %>"></label><label>Primary Color<input name="primary_color" value="<%= settings.primary_color || '#0f766e' %>"></label><button>Save Settings</button></form></main>
