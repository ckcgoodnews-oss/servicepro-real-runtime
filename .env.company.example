DATA_STORE=postgres
DATABASE_SSL=true
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DATABASE_PASSWORD@YOUR_SESSION_POOLER_HOST:5432/postgres

COMPANY_TENANT_ID=acme_services
COMPANY_NAME=Acme Services
COMPANY_OWNER_EMAIL=owner@acme.example
COMPANY_OWNER_PASSWORD=ReplaceWithUniqueCompanyPassword123!
COMPANY_SUPPORT_EMAIL=support@acme.example
COMPANY_SUPPORT_PHONE=555-0100
COMPANY_TIMEZONE=America/Indiana/Indianapolis
COMPANY_LOCALE=en-US
COMPANY_CURRENCY=USD

# Safety switches. Leave both false for a new company project.
ALLOW_EXISTING_DATABASE=false
KEEP_DEMO_DATA=false
