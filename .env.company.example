DATA_STORE=postgres
DATABASE_SSL=true
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DATABASE_PASSWORD@YOUR_SESSION_POOLER_HOST:5432/postgres

COMPANY_TENANT_ID=acme_services
COMPANY_NAME=Acme Services
COMPANY_OWNER_EMAIL=owner@acme.example
COMPANY_OWNER_PASSWORD=ReplaceWithUniqueCompanyPassword123!
COMPANY_SUPPORT_EMAIL=support@acme.example
COMPANY_SUPPORT_PHONE=555-0100
COMPANY_TIMEZONE=America/Indiana/Indianapolis
COMPANY_LOCALE=en-US
COMPANY_CURRENCY=USD

# Safety switches. Leave both false for a new company project.
ALLOW_EXISTING_DATABASE=false
KEEP_DEMO_DATA=false

# Sprint 742 deployment manifest metadata. The manifest never stores secrets.
SUPABASE_PROJECT_REF=yourprojectref
COMPANY_API_URL=https://company-api.onrender.com
COMPANY_WEB_URL=https://company.example.com
COMPANY_EXPECTED_VERSION=8.0.0-alpha.1
COMPANY_MANIFEST_FILE=reports/company-deployments/acme_services.json

# Sprint 744 provisioning-plan output. This file is secret-safe.
COMPANY_PROVISIONING_PLAN_FILE=reports/company-provisioning/acme_services.json
# Execution additionally requires CONFIRM_COMPANY_PROVISIONING=YES in the shell.
